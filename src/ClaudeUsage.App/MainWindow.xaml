<Window x:Class="ClaudeUsage.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude使用量"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <Window.Resources>

        <!-- 1プロバイダー分のパネル(ゲージ + エラー + テーブル) -->
        <DataTemplate x:Key="ProviderPanelTemplate">
            <StackPanel Width="292">

                <!-- ゲージ(制限バケット / クレジット等) -->
                <ItemsControl ItemsSource="{Binding Buckets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" FontSize="11.5" />
                                    <TextBlock Grid.Column="1" Text="{Binding ValueText}" FontSize="11.5"
                                               FontWeight="SemiBold" Foreground="{Binding ValueBrush}" />
                                </Grid>
                                <Grid Margin="0,3,0,0" Height="7" Visibility="{Binding BarVisibility}">
                                    <Border Background="{StaticResource BarBack}" CornerRadius="3.5" />
                                    <Border Background="{Binding BarBrush}" CornerRadius="3.5"
                                            HorizontalAlignment="Left" Width="{Binding BarWidth}" />
                                </Grid>
                                <TextBlock Text="{Binding ResetText}" FontSize="10" Margin="0,2,0,0"
                                           Foreground="{StaticResource FgDim}"
                                           Visibility="{Binding ResetVisibility}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding Error}" FontSize="10.5" Foreground="#FFB300"
                           TextWrapping="Wrap" Margin="0,2,0,4"
                           Visibility="{Binding ErrorVisibility}" />

                <!-- テーブル(ローカル集計 / 任意の行) -->
                <Border Background="{StaticResource BgSection}" CornerRadius="6" Padding="10,7" Margin="0,4,0,0"
                        Visibility="{Binding TableVisibility}">
                    <StackPanel>
                        <TextBlock Text="{Binding TableTitle}" FontSize="10.5"
                                   Foreground="{StaticResource FgDim}" Margin="0,0,0,5"
                                   Visibility="{Binding TableTitleVisibility}" />
                        <Grid Visibility="{Binding TableHeaderVisibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Header1}" FontSize="10" Foreground="{StaticResource FgDim}" />
                            <TextBlock Grid.Column="1" Text="{Binding Header2}" FontSize="10"
                                       Foreground="{StaticResource FgDim}" HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="2" Text="{Binding Header3}" FontSize="10"
                                       Foreground="{StaticResource FgDim}" HorizontalAlignment="Right" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding TableRows}" Margin="0,3,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1.5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" FontSize="11.5" FontWeight="SemiBold"
                                                   ToolTip="{Binding Tooltip}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11.5"
                                                   FontFamily="Consolas" HorizontalAlignment="Right"
                                                   ToolTip="{Binding Tooltip}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Value2}" FontSize="11.5"
                                                   FontFamily="Consolas" HorizontalAlignment="Right"
                                                   ToolTip="{Binding Tooltip}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding EmptyText}" FontSize="10.5"
                                   Foreground="{StaticResource FgDim}"
                                   Visibility="{Binding EmptyVisibility}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- 縦/横並び時のカード(プロバイダー名ヘッダー付き) -->
        <DataTemplate x:Key="ProviderCardTemplate">
            <Border BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8"
                    Padding="8,6" Margin="0,0,6,6" Background="#11FFFFFF">
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource Accent}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4" />
                    <ContentPresenter Content="{Binding}"
                                      ContentTemplate="{StaticResource ProviderPanelTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- タブヘッダー -->
        <DataTemplate x:Key="TabHeaderTemplate">
            <TextBlock Text="{Binding Name}" FontSize="11.5" />
        </DataTemplate>

        <ItemsPanelTemplate x:Key="HorizontalItemsPanel">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

    </Window.Resources>

    <Border CornerRadius="10" Background="{StaticResource Bg}" Padding="14,10,14,12"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <StackPanel>

            <!-- ヘッダー(ドラッグで移動) -->
            <Grid x:Name="HeaderBar" Background="Transparent" MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HeaderTitle" Text="Claude Code 使用量" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource IconButton}" Content="🔄"
                        ToolTipService.InitialShowDelay="300" ToolTipService.ShowDuration="5000"
                        Click="Refresh_Click">
                    <Button.ToolTip>
                        <ToolTip Placement="Bottom" Content="今すぐ更新" />
                    </Button.ToolTip>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource IconButton}" Content="✕"
                        ToolTipService.InitialShowDelay="300" ToolTipService.ShowDuration="5000"
                        Click="Hide_Click">
                    <Button.ToolTip>
                        <ToolTip Placement="Bottom" Content="トレイに格納" />
                    </Button.ToolTip>
                </Button>
            </Grid>

            <!-- プロバイダーパネル(単独 / タブ / 縦 / 横 はコードで組み立て) -->
            <ContentControl x:Name="PanelHost" Margin="0,8,0,0" />

            <!-- ステータス -->
            <TextBlock x:Name="StatusText" FontSize="9.5" Foreground="{StaticResource FgDim}"
                       Margin="0,7,0,0" Text="読込中..." />
        </StackPanel>
    </Border>
</Window>
